# Database — SQLite for development (swap to PostgreSQL for production)
# DATABASE_URL=sqlite:///./formflow.db
DATABASE_URL=
# Auth
JWT_SECRET=1234567890asdfgb
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# File Storage — local for development
UPLOAD_DIR=./uploads

# CORS — frontend origin
FRONTEND_ORIGIN=http://localhost:5173

# Email (optional)
SENDGRID_API_KEY=
RESEND_API_KEY=
FROM_EMAIL=
FROM_NAME=

GEMINI_API_KEY=

NVIDIA_API_KEY=

# AI (optional)
OPENAI_API_KEY=

# Google OAuth2 — for Drive & Sheets integrations
# Get these from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5173/integrations/google/callback

# Pexels API (for MoE image search agent)
PEXELS_API_KEY=

# MoE Agent Configuration
MOE_ORCHESTRATOR_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5
MOE_SUBAGENT_MODEL=meta/llama-3.3-70b-instruct

# Cloudinary (for file uploads)
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_CLOUD_NAME=
